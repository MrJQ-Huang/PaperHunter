# LLM 配置
# LLM_API_TYPE=anthropic 使用 /v1/messages；LLM_API_TYPE=openai 使用 /v1/chat/completions
LLM_API_TYPE=anthropic
LLM_API_KEY=tp-your-api-key-here
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
LLM_MODEL=xiaomi/mimo-v2.5-pro

# 可选：CC Switch/Claude/OpenAI JSON 配置路径；也可使用环境变量 ANTHROPIC_* 或 OPENAI_* 导入
CC_SWITCH_CONFIG_PATH=

# Semantic Scholar API Key (可选，提高限额)
SEMANTIC_SCHOLAR_API_KEY=

# Springer API Key (可选)
SPRINGER_API_KEY=

# Elsevier API Key (可选)
ELSEVIER_API_KEY=

# Unpaywall 邮箱 (用于查找 OA 版本)
UNPAYWALL_EMAIL=researcher@example.com

# 代理配置 (可选)
PROXY_URL=

# 下载目录
DOWNLOAD_DIR=./papers

# 数据库路径
DB_PATH=./data/papers.db
